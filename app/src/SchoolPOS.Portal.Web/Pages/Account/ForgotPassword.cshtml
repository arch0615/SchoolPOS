@page
@model SchoolPOS.Portal.Web.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar contraseña";
}
<div class="card" style="max-width:460px;margin:0 auto">
    <h1>Recuperar contraseña</h1>

    @if (Model.Submitted)
    {
        <div class="msg ok">Si el correo está registrado, se enviaron instrucciones para restablecer la contraseña.</div>
        @if (Model.DevResetLink is not null)
        {
            <p class="muted">Modo desarrollo — enlace de restablecimiento (en producción se envía por correo):</p>
            <p><a href="@Model.DevResetLink">Restablecer contraseña</a></p>
        }
        <a class="btn ghost" href="/Account/Login">Volver a ingresar</a>
    }
    else
    {
        <p class="muted">Ingresa tu correo y te enviaremos un enlace para restablecer tu contraseña.</p>
        <form method="post">
            <label>Correo electrónico</label>
            <input asp-for="Email" type="email" />
            <div style="margin-top:14px">
                <button class="btn" type="submit">Enviar enlace</button>
                <a class="btn ghost" href="/Account/Login">Cancelar</a>
            </div>
        </form>
    }
</div>
