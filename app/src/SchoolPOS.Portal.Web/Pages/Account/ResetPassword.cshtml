@page
@model SchoolPOS.Portal.Web.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Restablecer contraseña";
}
<div class="card" style="max-width:460px;margin:0 auto">
    <h1>Restablecer contraseña</h1>

    @if (!string.IsNullOrEmpty(Model.Error)) { <div class="msg error">@Model.Error</div> }

    <form method="post">
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Token" />
        <label>Nueva contraseña (mínimo 6 caracteres)</label>
        <input asp-for="NewPassword" type="password" />
        <div style="margin-top:14px"><button class="btn" type="submit">Guardar contraseña</button></div>
    </form>
</div>
