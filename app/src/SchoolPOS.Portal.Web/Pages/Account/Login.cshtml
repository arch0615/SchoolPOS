@page
@model SchoolPOS.Portal.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Ingresar";
}
<div class="card" style="max-width:460px;margin:0 auto">
    <h1>Ingresar</h1>

    @if (TempData["LoginMessage"] is string okMsg) { <div class="msg ok">@okMsg</div> }
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="msg error">@Model.Error</div>
    }

    <form method="post">
        <label>Correo electrónico</label>
        <input asp-for="Input.Email" type="email" />
        <label>Contraseña</label>
        <input asp-for="Input.Password" type="password" />
        <div style="margin-top:16px">
            <button class="btn" type="submit">Entrar</button>
            <a class="btn ghost" href="/Account/Register">Crear cuenta</a>
        </div>
        <p style="margin-top:12px"><a href="/Account/ForgotPassword">¿Olvidaste tu contraseña?</a></p>
    </form>
</div>
