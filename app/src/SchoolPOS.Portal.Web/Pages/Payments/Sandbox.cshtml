@page
@model SchoolPOS.Portal.Web.Pages.Payments.SandboxModel
@{
    ViewData["Title"] = "Pago (simulación)";
}
<div class="card" style="max-width:460px;margin:0 auto;text-align:center">
    <div class="pill">Pasarela de prueba</div>
    <h1 style="margin-top:12px">Confirmar pago</h1>
    <p class="muted">Simulación de Mercado Pago (desarrollo). En producción, aquí estaría el checkout real
        con split de comisión.</p>
    <div class="balance" style="color:#1e5aa8">@Model.Amount.ToString("C2")</div>
    <p class="muted">Referencia: @Model.Reference</p>

    <div style="margin-top:18px;display:flex;gap:10px;justify-content:center">
        <form method="post" asp-page-handler="Approve">
            <input type="hidden" name="reference" value="@Model.Reference" />
            <button class="btn accent" type="submit">Pagar (aprobar)</button>
        </form>
        <form method="post" asp-page-handler="Reject">
            <input type="hidden" name="reference" value="@Model.Reference" />
            <button class="btn danger" type="submit">Rechazar</button>
        </form>
    </div>
</div>
