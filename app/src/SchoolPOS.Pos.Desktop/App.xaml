<Application x:Class="SchoolPOS.Pos.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- Convertidores -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Paleta de marca LoncherApp -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#57A839" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#3F7F28" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F19234" />
        <SolidColorBrush x:Key="OrangeBrush" Color="#EFA43B" />
        <SolidColorBrush x:Key="LeafBrush" Color="#5FB03A" />
        <SolidColorBrush x:Key="DangerBrush" Color="#C0392B" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FAF6EC" />
        <SolidColorBrush x:Key="CreamBrush" Color="#FBF3DA" />
        <SolidColorBrush x:Key="InkBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#9A8F76" />

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
    </Application.Resources>
</Application>
