<Window x:Class="SchoolPOS.Pos.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SchoolPOS.Pos.Desktop.ViewModels"
        xmlns:views="clr-namespace:SchoolPOS.Pos.Desktop.Views"
        Title="LoncherApp — Punto de Venta" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen" Background="{StaticResource SurfaceBrush}">

    <Window.Resources>
        <!-- Mapeo view-model -> vista -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesViewModel}">
            <views:SalesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
            <views:InventoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditViewModel}">
            <views:AuditView />
        </DataTemplate>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Panel lateral de navegación -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,10">
                    <StackPanel Margin="16,0,12,14">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="30" Height="30" VerticalAlignment="Center">
                                <Canvas Width="64" Height="64">
                                    <Path Data="M32 21 C 27 13, 17 14, 15 24 C 13 33, 18 51, 27 51 C 30 51, 30 49, 32 49 C 34 49, 34 51, 37 51 C 46 51, 51 33, 49 24 C 47 14, 37 13, 32 21 Z"
                                          Stroke="White" StrokeThickness="4.5" StrokeLineJoin="Round" />
                                    <Path Data="M33 19 C 35 12, 41 9, 46 12" Stroke="White" StrokeThickness="3.2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Path Data="M31 19 C 24 9, 15 11, 20 18 C 24 23, 30 22, 31 19 Z" Fill="White" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="LoncherApp" Foreground="White" FontSize="19" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="Punto de Venta" Foreground="#DCEFD0" FontSize="12" Margin="2,3,0,0" />
                    </StackPanel>
                    <Button Content="🏠  Inicio" Style="{StaticResource NavButton}" Command="{Binding ShowDashboardCommand}" />
                    <Button Content="🛒  Venta" Style="{StaticResource NavButton}" Command="{Binding ShowSalesCommand}" />
                    <Button Content="📦  Inventario" Style="{StaticResource NavButton}"
                            Command="{Binding ShowInventoryCommand}"
                            Visibility="{Binding CanManageInventory, Converter={StaticResource BoolToVisibility}}" />
                    <Button Content="📈  Reportes" Style="{StaticResource NavButton}"
                            Command="{Binding ShowReportsCommand}"
                            Visibility="{Binding CanViewReports, Converter={StaticResource BoolToVisibility}}" />
                    <Button Content="📋  Bitácora" Style="{StaticResource NavButton}"
                            Command="{Binding ShowAuditCommand}"
                            Visibility="{Binding CanViewReports, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="18,10">
                    <TextBlock Text="{Binding OperatorName}" Foreground="White" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RoleName}" Foreground="#DCEFD0" FontSize="12" Margin="0,0,0,8" />
                    <Button Content="Cerrar sesión" Command="{Binding SignOutCommand}"
                            Background="{StaticResource PrimaryDarkBrush}" Foreground="White" BorderThickness="0" Padding="10,8" />
                </StackPanel>
                <Grid />
            </DockPanel>
        </Border>

        <!-- Contenido -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0" />
    </Grid>
</Window>
