<UserControl x:Class="SchoolPOS.Pos.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <TextBlock Text="Inicio" FontSize="24" FontWeight="Bold" Foreground="#333" />
            <Button Content="Actualizar" Command="{Binding RefreshCommand}" HorizontalAlignment="Right"
                    DockPanel.Dock="Right" />
        </DockPanel>

        <!-- Tarjetas de indicadores -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,0">
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,16,0" Width="220">
                <StackPanel>
                    <TextBlock Text="Ventas de hoy" Foreground="#888" />
                    <TextBlock Text="{Binding TodaySalesTotal, StringFormat='{}{0:C2}'}"
                               FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding TodaySalesCount, StringFormat='{}{0} operaciones'}" Foreground="#888" />
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="8" Padding="20" Width="220">
                <StackPanel>
                    <TextBlock Text="Bajo inventario" Foreground="#888" />
                    <TextBlock Text="{Binding LowStockCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}" />
                    <TextBlock Text="productos por debajo del mínimo" Foreground="#888" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Lista de bajo inventario -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Margin="0,18,0,0" Padding="16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Alertas de inventario" FontWeight="SemiBold"
                           FontSize="15" Margin="0,0,0,10" />
                <DataGrid ItemsSource="{Binding LowStockItems}" AutoGenerateColumns="False"
                          IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Existencias" Binding="{Binding StockOnHand}" Width="140" />
                        <DataGridTextColumn Header="Mínimo" Binding="{Binding MinStock}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
