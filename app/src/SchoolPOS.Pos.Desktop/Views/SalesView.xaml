<UserControl x:Class="SchoolPOS.Pos.Desktop.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <!-- Columna izquierda: productos y carrito -->
        <DockPanel Grid.Column="0" Margin="0,0,20,0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                <Viewbox Width="26" Height="26" Margin="0,0,10,0">
                    <Canvas Width="64" Height="64">
                        <Path Data="M32 21 C 27 13, 17 14, 15 24 C 13 33, 18 51, 27 51 C 30 51, 30 49, 32 49 C 34 49, 34 51, 37 51 C 46 51, 51 33, 49 24 C 47 14, 37 13, 32 21 Z"
                              Stroke="#EFA43B" StrokeThickness="4.5" StrokeLineJoin="Round" />
                        <Path Data="M33 19 C 35 12, 41 9, 46 12" Stroke="#EFA43B" StrokeThickness="3.2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        <Path Data="M31 19 C 24 9, 15 11, 20 18 C 24 23, 30 22, 31 19 Z" Fill="#5FB03A" />
                    </Canvas>
                </Viewbox>
                <TextBlock Text="Venta" FontSize="24" FontWeight="Bold" Foreground="{StaticResource InkBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" FontSize="16"
                         Text="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Escanee o escriba el código de barras…">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding AddProductCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="1" Content="Agregar" Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddProductCommand}" />
            </Grid>

            <StatusBar DockPanel.Dock="Bottom" Background="Transparent">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrush}" />
            </StatusBar>

            <DataGrid ItemsSource="{Binding Cart}" SelectedItem="{Binding SelectedLine}"
                      AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" Background="White" RowBackground="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto" Binding="{Binding Description}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="P. Unit." Binding="{Binding UnitPrice, StringFormat=C2}" Width="90" IsReadOnly="True" />
                    <DataGridTextColumn Header="Cant." Binding="{Binding Quantity, UpdateSourceTrigger=LostFocus}" Width="70" />
                    <DataGridTextColumn Header="Desc." Binding="{Binding Discount, UpdateSourceTrigger=LostFocus}" Width="80"
                                        IsReadOnly="{Binding DataContext.IsDiscountReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <DataGridTextColumn Header="Importe" Binding="{Binding LineTotal, StringFormat=C2}" Width="100" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Columna derecha: cliente y cobro -->
        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="18">
            <StackPanel>
                <TextBlock Text="Cliente" FontWeight="SemiBold" FontSize="15" />
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding StudentCode, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Matrícula o credencial">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding IdentifyStudentCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Content="Buscar" Command="{Binding IdentifyStudentCommand}" />
                </Grid>

                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding StudentName}" FontWeight="SemiBold" FontSize="14" />
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock Text="Saldo:" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding StudentBalanceText}" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right" />
                        </DockPanel>
                        <Button Content="Quitar" Command="{Binding ClearStudentCommand}" HorizontalAlignment="Left"
                                Margin="0,6,0,0" Padding="6,2" MinWidth="60"
                                Visibility="{Binding HasStudent, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Border>

                <Separator Margin="0,16" />

                <!-- Totales -->
                <DockPanel>
                    <TextBlock Text="Subtotal" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="{Binding Subtotal, StringFormat=C2}" HorizontalAlignment="Right" />
                </DockPanel>
                <DockPanel Margin="0,4,0,0">
                    <TextBlock Text="Descuentos" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="{Binding DiscountTotal, StringFormat=C2}" HorizontalAlignment="Right" />
                </DockPanel>
                <DockPanel Margin="0,8,0,0">
                    <TextBlock Text="Total" FontWeight="Bold" FontSize="20" />
                    <TextBlock Text="{Binding Total, StringFormat=C2}" FontWeight="Bold" FontSize="20"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right" />
                </DockPanel>

                <Separator Margin="0,16" />

                <!-- Forma de cobro -->
                <TextBlock Text="Forma de cobro" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <RadioButton Content="Saldo" IsChecked="{Binding IsBalanceTender}" Margin="0,0,16,0" />
                    <RadioButton Content="Efectivo" IsChecked="{Binding IsCashTender}" />
                </StackPanel>

                <StackPanel Visibility="{Binding IsCashTender, Converter={StaticResource BoolToVisibility}}" Margin="0,10,0,0">
                    <TextBlock Text="Efectivo recibido" Foreground="{StaticResource MutedBrush}" />
                    <TextBox Text="{Binding AmountReceived, UpdateSourceTrigger=PropertyChanged}" />
                    <DockPanel Margin="0,6,0,0">
                        <TextBlock Text="Cambio" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding Change, StringFormat=C2}" FontWeight="Bold" HorizontalAlignment="Right" />
                    </DockPanel>
                </StackPanel>

                <Button Content="Cobrar" Style="{StaticResource PrimaryButton}" Height="52" FontSize="18"
                        Margin="0,18,0,0" Command="{Binding ChargeCommand}" />
                <Button Content="Nueva venta" Command="{Binding NewSaleCommand}" Margin="0,4,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
